    "ecshare:smoke": "node scripts/dev/ec-share-api-smoke.mjs",
    "test": "npm run test:e2e -- e2e/api.spec.ts --project=chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "prisma generate"
  },
  "dependencies": {
