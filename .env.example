# Staging / production checklist（變數說明與核對順序）: docs/STAGING_ENV_CHECKLIST.md
#
# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Authentication ──
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional: Google / Gmail one-click sign-in via NextAuth.
# Google OAuth redirect URI:
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://easecity.hk/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ── EC-Share License JWT (Ed25519) ──
# Generate with: openssl genpkey -algorithm ed25519 -out license-private.pem
# Store escaped newlines in hosted secrets, never commit real key material.
LICENSE_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
LICENSE_JWT_KEY_ID=2026a
LICENSE_JWT_ISSUER=https://api.easecity.hk
LICENSE_JWT_AUDIENCE=ec-share-desktop

# ── EC-Share downloads / desktop updater ──
# Browser-facing installer URL. Leave empty until the signed Windows artifact is live.
NEXT_PUBLIC_EC_SHARE_WINDOWS_DOWNLOAD_URL=
# Browser-facing manifest URL (shown on /download). Server can override via EC_SHARE_DOWNLOAD_MANIFEST_URL.
NEXT_PUBLIC_EC_SHARE_DOWNLOAD_MANIFEST_URL=https://dl.easecity.hk/ec-share/windows/stable/latest.json
# Optional: force backend discovery JSON to a different URL than NEXT_PUBLIC_* (defaults unset).
EC_SHARE_DOWNLOAD_MANIFEST_URL=
EC_SHARE_DOWNLOAD_CHANNEL=stable

# ── Email Service ──
RESEND_API_KEY=
AUTH_EMAIL_FROM="EaseCity <onboarding@resend.dev>"
CONTACT_EMAIL_TO=hello@easecity.com

# ── Security ──
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Rate limiting (optional; production multi-instance) ──
# Leave unset to use in-memory limits (single instance / dev only).
# Create a free database at https://upstash.com — use REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Stripe ──
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs（在 Stripe Dashboard > Products 取得）
# Required Price metadata: product=ec_share, tier=pro/business/enterprise
# Canonical webhook URL: https://<your-domain>/webhooks/stripe
# Legacy compatibility URL: https://<your-domain>/api/payment/webhook
# Enable Stripe Tax in the Stripe Dashboard before production launch.
# Business seats are interpreted as at least 3 seats; Enterprise as at least 50 seats.
#
# 若僅設下方「legacy」三個 ID，定價頁會自動遞補：
#   Pro 月付 ← NEXT_PUBLIC_STRIPE_PRO_PRICE_ID
#   Pro 年付 ← STARTER 無則 PRO（若與你後台不符，請改設 PRO_ANNUAL）
#   Business 月／年 ← NEXT_PUBLIC_STRIPE_BIZ_PRICE_ID
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_ANNUAL_PRICE_ID=

NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_BIZ_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=

# Optional: `npm run ecshare:stripe-verify` — validates Stripe Price metadata (needs STRIPE_SECRET_KEY).

# ── Chatbot (OpenRouter – free models) ──
OPENROUTER_API_KEY=

# ── Cloudflare Turnstile ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
